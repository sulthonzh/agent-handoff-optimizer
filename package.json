{
  "name": "agent-handoff-optimizer",
  "version": "1.0.0",
  "description": "A specialized tool for optimizing and debugging agent handoffs in multi-agent systems",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "aho": "dist/cli.js"
  },
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format cjs",
    "dev": "tsup src/index.ts src/cli.ts --format cjs --watch",
    "test": "node test.mjs",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src tests --ext .ts",
    "lint:fix": "eslint src tests --ext .ts --fix",
    "prepare": "npm run build"
  },
  "keywords": [
    "agent",
    "handoff",
    "optimization",
    "multi-agent",
    "performance",
    "debugging",
    "ai-agents",
    "coordination"
  ],
  "author": "Sulthonzh",
  "license": "MIT",
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^15.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@typescript-eslint/eslint-plugin": "^6.2.0",
    "@typescript-eslint/parser": "^6.2.0",
    "@vitest/coverage-v8": "^4.0.0",
    "eslint": "^8.45.0",
    "tsup": "^7.0.0",
    "tsx": "^4.22.4",
    "typescript": "^5.0.0",
    "vitest": "^4.0.0"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}